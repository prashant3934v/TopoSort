#include <bits/stdc++.h> 
void dfs(int node, unordered_map<int,bool>&visited, unordered_map<int,list<int>> &adjList,stack<int>&st ){
    
    visited[node] = true;
    for(auto nb: adjList[node]){
        if(!visited[nb]){
           
            dfs(nb,visited,adjList,st);
        }
    }
    st.push(node);
}
vector<int> topologicalSort(vector<vector<int>> &edges, int v, int e)  {
    unordered_map<int,list<int>>adjList;
    for(int i=0; i<edges.size(); i++){
        int u = edges[i][0];
        int v = edges[i][1];
        adjList[u].push_back(v);
    }
    unordered_map<int,bool>visited;
    stack<int>st;
    for(int i=0; i<v; i++){
        if(!visited[i]){
            dfs(i,visited,adjList,st);
        }
    }
    vector<int>ans;
    while(!st.empty()){
        ans.push_back(st.top());
        st.pop();
    }
    return ans;

    
}
